{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs pre-bash",
                        "timeout": 5000
                    },
                    {
                        "type": "command",
                        "command": "lean-ctx hook rewrite",
                        "timeout": 5000
                    }
                ]
            },
            {
                "matcher": "Read|Grep|Glob|View",
                "hooks": [
                    {
                        "type": "command",
                        "command": "lean-ctx hook redirect",
                        "timeout": 5000
                    }
                ]
            },
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs pre-edit",
                        "timeout": 5000
                    }
                ]
            },
            {
                "matcher": "Skill",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/model-router-hook.cjs",
                        "timeout": 5000
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/token-tracker.cjs pre-tool",
                        "timeout": 3000
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/hooks/token-accum.cjs record",
                        "timeout": 2000
                    }
                ]
            },
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs post-edit",
                        "timeout": 10000
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/alignment-hook.cjs check",
                        "timeout": 5000
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/harness-gate-check.cjs",
                        "timeout": 5000
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs post-bash",
                        "timeout": 5000
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs session-restore",
                        "timeout": 15000
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hooks/auto-memory-hook.mjs import",
                        "timeout": 8000
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/hooks/monitor-session.cjs start",
                        "timeout": 3000
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs session-end",
                        "timeout": 10000
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/hooks/monitor-session.cjs end",
                        "timeout": 3000
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/auto-memory-hook.mjs sync",
                        "timeout": 10000
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "matcher": "manual",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs compact-manual"
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs session-end",
                        "timeout": 5000
                    }
                ]
            },
            {
                "matcher": "auto",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs compact-auto"
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs session-end",
                        "timeout": 6000
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs status",
                        "timeout": 3000
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/hooks/monitor-hooks.cjs start",
                        "timeout": 3000
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs post-task",
                        "timeout": 5000
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/hooks/monitor-hooks.cjs end",
                        "timeout": 3000
                    },
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/hooks/monitor-hooks.cjs push",
                        "timeout": 3000
                    }
                ]
            }
        ],
        "Notification": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "node {IDE_ROOT}/helpers/hook-handler.cjs notify",
                        "timeout": 3000
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": [
            "Bash(npx @claude-flow*)",
            "Bash(npx claude-flow*)",
            "Bash(node {IDE_ROOT}/*)",
            "mcp__claude-flow__:*"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)"
        ]
    },
    "verbose": true,
    "attribution": {
        "commit": "Co-Authored-By: claude-flow <ruv@ruv.net>",
        "pr": "🤖 Generated with [claude-flow](https://github.com/ruvnet/claude-flow)"
    },
    "env": {
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
        "CLAUDE_FLOW_V3_ENABLED": "true",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDECODENOFLICKER": "1",
        "CLAUDE_CODE_ALWAYS_THINKING": "0",
        "CLAUDE_CODE_VERBOSE": "1",
        "CLAUDE_CODE_ENABLE_THINKING": "0",
        "CLAUDE_CODE_STREAM_DELAY": "0"
    },
    "model": "deepseek-v4-flash",
    "modelPreferences": {
        "preferred": "deepseek-v4-flash",
        "fallbacks": [
            "deepseek-v4-pro"
        ],
        "automaticallySwitch": true
    },
    "claudeFlow": {
        "version": "3.0.0",
        "enabled": true,
        "agentTeams": {
            "enabled": true,
            "teammateMode": "auto",
            "taskListEnabled": true,
            "mailboxEnabled": true,
            "coordination": {
                "autoAssignOnIdle": true,
                "trainPatternsOnComplete": true,
                "notifyLeadOnComplete": true,
                "sharedMemoryNamespace": "agent-teams"
            },
            "hooks": {
                "teammateIdle": {
                    "enabled": true,
                    "autoAssign": true,
                    "checkTaskList": true
                },
                "taskCompleted": {
                    "enabled": true,
                    "trainPatterns": true,
                    "notifyLead": true
                }
            }
        },
        "swarm": {
            "topology": "hierarchical-mesh",
            "maxAgents": 15
        },
        "memory": {
            "backend": "hybrid",
            "enableHNSW": true,
            "learningBridge": {
                "enabled": true
            },
            "memoryGraph": {
                "enabled": true
            },
            "agentScopes": {
                "enabled": true
            }
        },
        "neural": {
            "enabled": true
        },
        "daemon": {
            "autoStart": false,
            "workers": [
                "map",
                "audit",
                "optimize"
            ],
            "schedules": {
                "audit": {
                    "interval": "4h",
                    "priority": "critical"
                },
                "optimize": {
                    "interval": "2h",
                    "priority": "high"
                }
            }
        },
        "learning": {
            "enabled": true,
            "autoTrain": true,
            "patterns": [
                "coordination",
                "optimization",
                "prediction"
            ],
            "retention": {
                "shortTerm": "24h",
                "longTerm": "30d"
            }
        },
        "security": {
            "autoScan": true,
            "scanOnEdit": true,
            "cveCheck": true,
            "threatModel": true
        }
    },
    "mcpServers": {
        "lean-ctx": {
            "command": "lean-ctx",
            "args": []
        }
    }
}

